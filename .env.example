# ─── Banco de dados ───────────────────────────────────────────────────
POSTGRES_USER=codegames
POSTGRES_PASSWORD=codegames_dev
POSTGRES_DB=codegames
POSTGRES_PORT=5432

# ─── API (apps/api) ───────────────────────────────────────────────────
DATABASE_URL="postgresql://codegames:codegames_dev@localhost:5432/codegames"
PORT=3001

# JWT — troque por valores longos e aleatórios em produção
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Tempo de expiração
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt rounds (10 é seguro; aumente em prod se o hardware suportar)
BCRYPT_ROUNDS=10

# ─── Web (apps/web) ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
